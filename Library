-- ── palette ─────────────────────────────────────────────────────
local BG0   = Color3.fromRGB(13,13,20)
local BG1   = Color3.fromRGB(19,17,31)
local BG2   = Color3.fromRGB(26,23,48)
local BG3   = Color3.fromRGB(36,31,69)
local TXT   = Color3.fromRGB(224,214,245)
local DIM   = Color3.fromRGB(139,122,173)
